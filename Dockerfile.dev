# =============================================================================
# Codelabz — Development Dockerfile
# =============================================================================
# Provides a development environment with:
#   • Node 18 (matches production)
#   • OpenJDK 17 JRE (required by Firebase Emulators)
#   • Firebase CLI
#   • Vite dev server with hot-reload
# =============================================================================

FROM node:18-slim

# Install JRE for Firebase Emulators + essential tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    openjdk-17-jre-headless \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Firebase CLI globally
RUN npm install -g firebase-tools

WORKDIR /app

# Copy dependency manifests and install
COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps

# Copy Firebase functions dependencies
WORKDIR /app/functions
COPY functions/package.json functions/package-lock.json* ./
RUN npm install --legacy-peer-deps || true
WORKDIR /app

# Copy remaining source code
COPY . .

# Copy and prepare the entrypoint script
COPY scripts/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Expose ports:
#   5173 — Vite dev server
#   4000 — Firebase Emulator UI
#   9099 — Auth emulator
#   8080 — Firestore emulator
#   9000 — Realtime Database emulator
#   5001 — Functions emulator
#   8085 — Pub/Sub emulator
#   9199 — Storage emulator
EXPOSE 5173 4000 9099 8080 9000 5001 8085 9199

CMD ["/usr/local/bin/entrypoint.sh"]
